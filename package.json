{
  "name": "atelier-x-experience",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "validate:env": "node scripts/validate-env.mjs",
    "release:check": "npm run validate:env && npm run release:audit && npm run ci",
    "clean": "rm -rf .next coverage playwright-report test-results",
    "deadcode": "tsc --noEmit",
    "db:types": "supabase gen types typescript --local > src/lib/database.generated.ts",
    "db:check": "npm run db:types && git diff --exit-code src/lib/database.generated.ts",
    "test:coverage": "vitest run --coverage",
    "release:audit": "node scripts/release-audit.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.0",
    "@react-three/drei": "^10.7.0",
    "@react-three/fiber": "^9.3.0",
    "@react-three/postprocessing": "^3.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.0",
    "gsap": "^3.13.0",
    "leva": "^0.10.0",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "postprocessing": "^6.37.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0",
    "sonner": "^2.0.7",
    "split-type": "^0.3.4",
    "tailwind-merge": "^3.3.1",
    "three": "^0.180.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.0",
    "zustand": "^5.0.8",
    "lenis": "^1.3.11",
    "@supabase/supabase-js": "^2.57.4",
    "@supabase/ssr": "^0.7.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "sharp": "^0.34.3",
    "blurhash": "^2.0.5",
    "@upstash/redis": "^1.35.3",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.180.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "typescript": "^5.9.0",
    "eslint": "^9.35.0",
    "eslint-config-next": "^16.0.0",
    "globals": "^16.3.0",
    "@next/bundle-analyzer": "^16.0.0",
    "vitest": "^3.2.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.8.0",
    "jsdom": "^26.1.0",
    "@playwright/test": "^1.55.0",
    "supabase": "^2.39.2",
    "axe-core": "^4.10.3",
    "@axe-core/playwright": "^4.10.2",
    "@vitest/coverage-v8": "^3.2.4"
  }
}